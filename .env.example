# ====================================================================
# Job Hunt Hacker — env. Copy to .env and fill what you want.
# Nothing is required. The app runs offline with safe defaults.
# ====================================================================

# ----- LLM providers (optional — without any, the app uses template
# fallbacks that still produce honest, evidence-grounded output) -----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=                       # e.g. http://localhost:11434/v1 for Ollama
OLLAMA_BASE_URL=                       # e.g. http://localhost:11434
JHH_LLM_PROVIDER=auto                  # auto | anthropic | openai | ollama | template
JHH_LLM_MODEL=                         # e.g. claude-sonnet-4-6 or gpt-4o-mini

# ----- Embeddings (optional — falls back to hashing TF-IDF) -----
JHH_EMBED_PROVIDER=auto                # auto | openai | local | hash
JHH_EMBED_MODEL=                       # e.g. text-embedding-3-small

# ----- Job sources (optional API keys) -----
SERPAPI_API_KEY=                       # enables Google Jobs adapter
SEARCHAPI_API_KEY=                     # alternate Google Jobs provider
GITHUB_TOKEN=                          # raises GitHub API rate limit during repo ingest

# ----- Gmail / Calendar (optional, OAuth) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8731/oauth/google/callback
IMAP_HOST=
IMAP_USER=
IMAP_PASS=

# ----- Server -----
JHH_HOST=127.0.0.1
JHH_PORT=8731
JHH_DB_PATH=data/jhh.db
JHH_DATA_DIR=data
JHH_UPLOADS_DIR=uploads
JHH_RESUMES_DIR=resumes
JHH_PACKETS_DIR=packets

# ----- Compliance + safety -----
JHH_AUTO_APPLY_ENABLED=false           # MUST stay false unless you accept TOS risk
JHH_AUTO_APPLY_DAILY_CAP=5
JHH_AUTO_APPLY_MIN_SCORE=85
JHH_DEFAULT_MODE=assisted              # research | assisted | auto
